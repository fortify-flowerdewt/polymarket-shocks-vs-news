# ---- macOS ----
.DS_Store

# ---- Python ----
__pycache__/
*.py[oc]
build/
wheels/
*.egg-info
.venv/

# ---- Node / Observable ----
node_modules/
**/.observablehq/cache/

# ---- Large raw data (regenerable) ----
# HuggingFace dataset + derived OHLCV parquet shards (~900 MB).
# Root-anchored so we don't accidentally exclude dashboard/src/data/.
/data/

# ---- Caches and intermediate artifacts (regenerable from the data/ sources) ----
# Everything in output/ is regenerable from the pipeline — except the published
# memo at output/phase0/ which we deliberately keep.
output/wiki_cache.json
output/gdelt_cache.json
output/shocks.parquet
output/shocks_shortlist.parquet
output/aligned_wiki.parquet
output/news_wikipedia.parquet
output/news_gdelt.parquet
output/watchlist.parquet
output/watchlist_sports.parquet
output/backtest/
output/backtest_sports/
output/dashboard/
output/*.log

# Dashboard payload (dashboard/src/data/*) IS kept — those drive the live
# GitHub Pages site and would require uploading the 5 GB HuggingFace dataset
# to CI to regenerate, which is impractical.

# ---- Editor / IDE ----
.idea/
.vscode/
.claude/
phase1/ledger.sqlite
phase1/paper_trader.log
